{
    "name": "notonza/php-support",
    "description": "A PHP library for supporting utilities and features.",
    "type": "library",
    "keywords": [
        "php",
        "utilities",
        "helpers",
        "string-functions",
        "array-functions",
        "support"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Kangin Kim",
            "email": "gachakra.kangin@notonza.dev"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "ext-pdo": "*",
        "ext-mbstring": "*",
        "ext-zip": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "~12.0",
        "brianium/paratest": "~v7",
        "vimeo/psalm": "~6",
        "friendsofphp/php-cs-fixer": "~3",
        "jetbrains/phpstorm-attributes": "~1"
    },
    "autoload": {
        "psr-4": {
            "Notonza\\Support\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Notonza\\Support\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml",
        "static-analysis": "psalm"
    },
    "config": {
        "optimize-autoloader": true
    }
}